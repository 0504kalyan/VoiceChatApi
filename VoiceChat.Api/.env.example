# Copy to ".env" (git-ignored). Paths checked: cwd, cwd/Api/VoiceChat.Api/.env, bin folder, project folder.
#
# OAuth — Google__* (same names as environment variables).
# Google Cloud → Authorized redirect URI: http://localhost:5292/signin-google
Google__ClientId=
Google__ClientSecret=

# SMTP (OTP + forgot-password email delivery)
# Gmail requires App Password, not your normal Gmail password.
Email__SmtpHost=smtp.gmail.com
Email__SmtpPort=587
Email__UseSsl=true
Email__SmtpUser=
Email__SmtpPassword=
Email__FromAddress=
Email__FromName=VoiceChat

# Gemini — create an API key in Google AI Studio.
# Keep this on the API/server only. Never put it in Angular environment files.
Gemini__ApiKey=
Gemini__DefaultModel=gemini-2.5-flash
Gemini__EnableGoogleSearchGrounding=true
# Optional dropdown entries:
# Gemini__AvailableModels__0=gemini-2.5-flash
# Gemini__AvailableModels__1=gemini-2.5-flash-lite
# Gemini__AvailableModels__2=gemini-2.5-pro
# Gemini__AvailableModels__3=gemini-2.0-flash

# Supabase — process env name maps to SupabaseCredentials:ConnectionString in .NET.
# SupabaseCredentials__ConnectionString=Host=...;Port=5432;Database=postgres;Username=...;Password=...;SSL Mode=Require;Trust Server Certificate=true
# Or: ConnectionStrings__DefaultConnection=<same string>
