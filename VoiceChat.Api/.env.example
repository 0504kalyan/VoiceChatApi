# Copy to ".env" (git-ignored) next to VoiceChat.Api.csproj.
#
# OAuth — GoogleCredentials__* (same keys on Render).
# Google Cloud → Authorized redirect URI: http://localhost:5292/signin-google
GoogleCredentials__ClientId=
GoogleCredentials__ClientSecret=

# Supabase — full Npgsql string including Password= (appsettings has Password= empty; do not commit real passwords).
# Example: Host=db.xxx.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=YOUR_DB_PASSWORD;SSL Mode=Require;Trust Server Certificate=true
SupabaseCredentials__ConnectionString=
# Or: ConnectionStrings__DefaultConnection=<same string>
