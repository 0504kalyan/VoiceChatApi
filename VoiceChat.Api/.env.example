# Copy to ".env" (git-ignored) next to VoiceChat.Api.csproj.
#
# OAuth — use GoogleCredentials__* (same on Render). Real values must NOT be committed to git.
# Optional: Google__ClientId / Google__ClientSecret (direct bind to Google: section).
#
# Google Cloud → Authorized redirect URI: http://localhost:5292/signin-google

GoogleCredentials__ClientId=
GoogleCredentials__ClientSecret=
